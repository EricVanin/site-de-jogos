{
  "name": "site-de-jogos",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.3.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev:server": "pnpm --filter @site-de-jogos/server dev",
    "dev:web": "pnpm --filter @site-de-jogos/web dev",
    "lint": "pnpm -r lint",
    "postinstall": "pnpm --filter @site-de-jogos/shared build",
    "start": "pnpm --filter @site-de-jogos/server start",
    "test": "pnpm -r test",
    "check": "pnpm lint && pnpm build && pnpm test"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.14.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.24.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "jsdom": "^26.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.29.1",
    "vite": "^6.3.2",
    "vitest": "^3.1.1"
  }
}
